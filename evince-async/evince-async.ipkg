package evince-async
version = 0.6.0
authors = "Alexandr Chigrinets"
license = "MIT"
brief = "Async-based concurrent runner for evince"

depends = evince
        , async

modules = Evince.Async
        , Evince.Async.Spec
        , Evince.Async.Synchronized
        , Evince.Async.Hoist
        , Evince.Async.Reporter
        , Evince.Async.Shared
        , Evince.Async.Runner

sourcedir = "src"
